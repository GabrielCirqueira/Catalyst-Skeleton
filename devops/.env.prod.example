# devops/.env.prod.example — Referência das variáveis de produção
#
# ⚠ ATENÇÃO: Este arquivo é apenas documentação de referência.
#    O deploy.sh gera o .env de produção automaticamente com segredos aleatórios.
#    NÃO É NECESSÁRIO copiar ou editar este arquivo antes do deploy.
#
# Se precisar ajustar manualmente após o deploy, edite o .env na raiz do projeto.

# ── Symfony ───────────────────────────────────────────────────────────────────
APP_ENV=prod
APP_DEBUG=false
APP_SECRET=<gerado automaticamente — 64 chars hex>

# ── Banco de dados ────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=<gerado automaticamente>
MYSQL_DATABASE=<nome informado no deploy interativo>
MYSQL_USER=<usuário informado no deploy interativo>
MYSQL_PASSWORD=<gerado automaticamente>
DATABASE_URL="mysql://usuario:senha@database:3306/banco?serverVersion=8.0.32&charset=utf8mb4"

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=<gerado automaticamente — 64 chars hex>
JWT_TTL=3600

# ── Frontend ──────────────────────────────────────────────────────────────────
# URL pública da API — definida pelo domínio informado no deploy interativo
VITE_API_URL=https://seu-dominio.com
VITE_API_BASE_URL=https://seu-dominio.com

# ── Mensageria ────────────────────────────────────────────────────────────────
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0

# ── Mailer ────────────────────────────────────────────────────────────────────
# Padrão: null (sem envio). Troque pelo SMTP real quando necessário.
MAILER_DSN=null://null
# Exemplo SMTP: MAILER_DSN=smtp://usuario:senha@smtp.provider.com:587

# ── Certbot (SSL) ─────────────────────────────────────────────────────────────
CERTBOT_DOMAIN=seu-dominio.com
CERTBOT_EMAIL=admin@seu-dominio.com
