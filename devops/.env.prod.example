# devops/.env.prod.example — Template de variáveis de produção
#
# Copie este arquivo para .env na RAIZ do projeto no servidor e preencha os valores.
# NUNCA commite o .env com valores reais — ele está no .gitignore.
#
#   cp devops/.env.prod.example .env
#   nano .env

# ── Symfony ───────────────────────────────────────────────────────────────────
APP_ENV=prod
APP_DEBUG=false
APP_SECRET=TROQUE_POR_32_CHARS_ALEATORIOS_AQUI

# ── Banco de dados ────────────────────────────────────────────────────────────
# Usado pelo docker-compose.prod.yml para criar o banco MySQL
MYSQL_ROOT_PASSWORD=SENHA_ROOT_FORTE
MYSQL_DATABASE=NOME_DO_BANCO
MYSQL_USER=USUARIO_DO_BANCO
MYSQL_PASSWORD=SENHA_DO_BANCO

# Usado pelo Symfony para conectar ao banco (deve bater com os valores acima)
DATABASE_URL="mysql://${MYSQL_USER}:${MYSQL_PASSWORD}@database:3306/${MYSQL_DATABASE}?serverVersion=8.0.32&charset=utf8mb4"

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=PASSPHRASE_FORTE_AQUI
JWT_TTL=3600

# ── Frontend ──────────────────────────────────────────────────────────────────
# URL pública da API usada no build do React/Vite (sem barra no final)
VITE_API_URL=https://seu-dominio.com

# Porta exposta pelo container da aplicação no host
BACKEND_PORT=8000

# ── Mensageria ────────────────────────────────────────────────────────────────
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0

# ── Mailer ────────────────────────────────────────────────────────────────────
MAILER_DSN=smtp://usuario:senha@smtp.seuprovedor.com:587
