# define your env variables for the test env here
KERNEL_CLASS='App\Kernel'
APP_SECRET='$ecretf0rt3st'
SYMFONY_DEPRECATIONS_HELPER=ignoreFile=./tests/.phpunit.deprecations-ignore
PANTHER_APP_ENV=panther
PANTHER_ERROR_SCREENSHOT_DIR=./var/error-screenshots

# doctrine.yaml appends _test suffix in test env → effective DB = skeleton_test
# root credentials required: skeleton user has no access to skeleton_test
DATABASE_URL="mysql://root:root@database:3306/skeleton?serverVersion=8.0.32&charset=utf8mb4"
