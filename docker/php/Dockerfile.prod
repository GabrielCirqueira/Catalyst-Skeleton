# ──────────────────────────────────────────────────────────────────────────────
# Dockerfile.prod — imagem de produção do Catalyst Skeleton
#
# Contém: PHP-FPM + Nginx interno + Supervisord
# O container expõe HTTP na porta 80.
# O Nginx do host faz proxy_pass para a porta mapeada (ex: 127.0.0.1:8080:80).
#
# Build feito pelo devops/deploy.sh via docker compose build.
# Para build manual: docker build -f docker/php/Dockerfile.prod -t catalyst-prod .
# ──────────────────────────────────────────────────────────────────────────────

# --- Builder: instala dependências PHP sem pacotes de dev ---
FROM php:8.4-fpm-alpine AS builder

COPY --from=composer:latest /usr/bin/composer /usr/bin/composer

RUN apk add --no-cache \
    git bash libzip-dev icu-dev oniguruma-dev \
    && docker-php-ext-install pdo_mysql zip intl opcache

WORKDIR /app
COPY composer.json composer.lock ./
RUN composer install --no-dev --no-scripts --optimize-autoloader --no-interaction

COPY . .
RUN composer dump-autoload --optimize

# --- Frontend builder: compila assets Vite/React para public/build/ ---
FROM node:22-alpine AS frontend-builder

WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci --legacy-peer-deps
COPY . .
RUN npm run build

# --- Imagem final de produção ---
FROM php:8.4-fpm-alpine

RUN apk add --no-cache \
    bash libzip-dev icu-dev oniguruma-dev \
    nginx supervisor curl openssl netcat-openbsd \
    && docker-php-ext-install pdo_mysql zip intl opcache \
    && mkdir -p /run/nginx /var/log/supervisor

WORKDIR /var/www/html

# Configurações PHP de produção
COPY docker/php/php.prod.ini /usr/local/etc/php/conf.d/php.ini

# Pool PHP-FPM: clear_env=no para que os workers herdem as variáveis do container
COPY docker/php/www.conf /usr/local/etc/php-fpm.d/www.conf

# Nginx interno: escuta na 80 e passa para php-fpm em 127.0.0.1:9000
COPY docker/php/nginx-internal.conf /etc/nginx/http.d/default.conf

# Supervisord: gerencia nginx + php-fpm como processos filhos
COPY docker/php/supervisord-prod.conf /etc/supervisord-prod.conf

# Copia a aplicação compilada pelo builder
COPY --from=builder --chown=www-data:www-data /app /var/www/html

# Copia os assets do frontend (Vite build → public/build/)
COPY --from=frontend-builder --chown=www-data:www-data /app/public/build /var/www/html/public/build

RUN mkdir -p /var/www/html/var/cache /var/www/html/var/log \
    && chown -R www-data:www-data /var/www/html/var

# bootstrap.sh roda antes do supervisord:
# gera JWT keys, aguarda DB, roda migrations, aquece cache
COPY --chmod=755 docker/bootstrap.sh /usr/local/bin/entrypoint.sh

EXPOSE 80
ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
CMD ["/usr/bin/supervisord", "-c", "/etc/supervisord-prod.conf"]
